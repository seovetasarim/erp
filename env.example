# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Auth (min 32 karakter rastgele string)
AUTH_SECRET=buraya-en-az-32-karakterlik-gizli-anahtar-yazin

# ERP lisans secret — Desktop\erp\electron\license.secret ile AYNI olmalı
DIJITALERP_LICENSE_SECRET=
# veya dosya yolu:
# DIJITALERP_LICENSE_SECRET_PATH=C:\Users\A\Desktop\erp\electron\license.secret

# PayTR (Mağaza Paneli → BİLGİ)
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
PAYTR_TEST_MODE=1

# SQLite (geliştirme — DB_DRIVER ayarlanmazsa)
# DATABASE_PATH=

# MySQL (canlı — cPanel)
# DB_DRIVER=mysql
# MYSQL_HOST=104.247.173.212
# MYSQL_PORT=3306
# MYSQL_USER=
# MYSQL_PASSWORD=
# MYSQL_DATABASE=
#
# Vercel'de tek satir (Production) — sifrede * varsa %2A kullanin:
# DATABASE_URL=mysql://dijitalerpcom_dijitalerp:SIFRE@104.247.173.212:3306/dijitalerpcom_erpprogrami

# PayTR callback URL (canlıda):
# https://www.dijitalerp.com.tr/api/paytr/callback

# ERP uzaktan lisans URL (müşteriye verilecek):
# https://www.dijitalerp.com.tr/api/licenses/remote

# E-posta (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="DijitalERP" <noreply@dijitalerp.com.tr>

# Yönetici paneli (/admin)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=guclu-bir-sifre-buraya
# ADMIN_SECRET= (opsiyonel, yoksa AUTH_SECRET kullanılır)

# Cron — aylık yenileme hatırlatmaları
# GET /api/cron/subscriptions  Authorization: Bearer CRON_SECRET
CRON_SECRET=
